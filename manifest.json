{
  "manifest_version": 3,
  "name": "Koofr WebDAV Video Grabber",
  "version": "1.0",
  "description": "Detects streams and saves them to Koofr WebDAV automatically.",
  "permissions": [
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "https://app.koofr.net/dav/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
