{
  "manifest_version": 3,
  "name": "Koofr WebDAV Grabber",
  "version": "2.0",
  "description": "Click to grab and upload current page videos to Koofr WebDAV.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://app.koofr.net/dav/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
